# Copy to `.env` (gitignored) and fill in. Used ONLY by src/precompute/* scripts.
# rank.py never reads these — it touches no network and no LLM (the golden rule).

# Google AI Studio — Gemini 2.5 Flash (recommended default, ~1500 req/day free).
GEMINI_API_KEY=

# Optional fallback lanes (OpenAI-compatible endpoints). Leave blank if unused.
GROQ_API_KEY=
OPENROUTER_API_KEY=
