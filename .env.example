# Copy to `.env` (gitignored) and fill in. Used ONLY by src/precompute/* scripts.
# rank.py never reads these — it touches no network and no LLM (the golden rule).

# Google AI Studio — Gemini (used for the JD rubric in Session 03). NOTE: the free
# tier on our key allowed only ~20 requests/day, too few for the bulk extraction.
GEMINI_API_KEY=

# OpenAI-compatible fallback lanes. Cerebras (~1M tokens/day, gpt-oss-120b) carried
# the Session-04 extraction; Groq's llama-3.3-70b is ~100k tokens/day. Leave blank
# if unused. The provider is selected with `--provider` (default: cerebras).
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
