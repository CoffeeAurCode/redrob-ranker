{
  "rubric": {
    "role_archetypes": [
      "Applied ML Engineer",
      "Search Engineer",
      "Ranking Engineer",
      "Recommendation Systems Engineer",
      "ML Systems Engineer (with focus on applied IR/NLP)"
    ],
    "must_haves": [
      "Demonstrated experience deploying and maintaining embeddings-based retrieval systems in production for real users, including handling operational challenges like embedding drift, index refresh, and quality regression.",
      "Proven hands-on experience with vector databases or hybrid search infrastructure (e.g., Pinecone, Weaviate, Qdrant, Milvus, OpenSearch, Elasticsearch, FAISS) in a production setting.",
      "Strong Python coding skills, evidenced by contributions to production systems or significant open-source projects.",
      "Ability to design and implement rigorous evaluation frameworks for ranking systems, including offline metrics (NDCG, MRR, MAP) and online A/B testing interpretation.",
      "Career history showing successful delivery of at least one end-to-end ranking, search, or recommendation system to real users at meaningful scale.",
      "Ability to articulate and defend architectural and strategic decisions regarding retrieval (hybrid vs dense), evaluation (offline vs online), and LLM integration (fine-tuning vs prompting), backed by practical experience building such systems.",
      "Recent (within the last 18 months) hands-on production coding experience.",
      "Career primarily in product-focused companies, demonstrating a product-engineering mindset and willingness to ship iteratively to learn from users."
    ],
    "nice_to_haves": [
      "Experience with LLM fine-tuning techniques (e.g., LoRA, QLoRA, PEFT).",
      "Experience with learning-to-rank models (e.g., XGBoost-based or neural networks).",
      "Prior exposure to HR-tech, recruiting tech, or marketplace products.",
      "Background in distributed systems or large-scale inference optimization.",
      "Open-source contributions in the AI/ML space.",
      "Willingness to relocate to or currently located in Noida or Pune, India.",
      "Ability to join with a notice period of 30 days or less."
    ],
    "hard_disqualifiers": [
      "Career spent exclusively in pure research environments (academic labs, research-only roles) without any production deployment experience.",
      "AI experience limited primarily to recent (under 12 months) projects using LLM frameworks (e.g., LangChain to call OpenAI) without substantial pre-LLM-era ML production experience.",
      "No production coding experience in the last 18 months due to a shift into purely 'architecture' or 'tech lead' roles.",
      "Career trajectory indicating frequent job changes (e.g., every 1.5 years) primarily for title progression.",
      "Primary focus on demonstrating framework usage (e.g., LangChain tutorials, blog posts on hot frameworks) rather than deep system design and problem-solving.",
      "Career exclusively in IT consulting/services firms (e.g., TCS, Infosys, Wipro, Accenture, Cognizant, Capgemini) without prior product company experience.",
      "Primary ML expertise is in computer vision, speech, or robotics without significant NLP/Information Retrieval exposure.",
      "Work has been entirely on closed-source proprietary systems for 5+ years without any external validation (e.g., papers, talks, open-source contributions)."
    ],
    "domains": [
      "Information Retrieval",
      "Ranking Systems",
      "Recommendation Systems",
      "Natural Language Processing (NLP)",
      "Machine Learning System Evaluation",
      "Embeddings",
      "Large Language Models (LLMs)"
    ],
    "seniority_band": {
      "min_years": 5.0,
      "max_years": 9.0,
      "notes": "While the stated range is 5-9 years, the ideal candidate typically has 6-8 years of total experience, with 4-5 years specifically in applied ML/AI roles at product companies. Strong candidates outside this band will be seriously considered if other signals are compelling."
    }
  },
  "ideal_text": "The ideal candidate is an experienced Applied ML Engineer with 6-8 years of total experience, including 4-5 years dedicated to building and deploying machine learning systems within product-focused companies. They possess deep technical expertise in modern ML systems, particularly in embeddings-based retrieval, ranking, and LLM integration, evidenced by their history of shipping end-to-end search, ranking, or recommendation systems to real users at scale. This individual thrives in ambiguous, fast-paced environments, demonstrating a scrappy product-engineering attitude by prioritizing iterative delivery and learning from user feedback over theoretical perfection. They have hands-on experience designing and implementing robust evaluation frameworks for ranking systems, including offline metrics and online A/B testing, and can articulate and defend their architectural choices based on practical experience. Crucially, they are a hands-on coder who has consistently contributed production-level code within the last 18 months, and their career trajectory reflects a commitment to building impactful systems rather than solely pursuing titles or framework-centric demos. Their background is rooted in practical application, not pure research or IT consulting, and their expertise is firmly in NLP/Information Retrieval domains.",
